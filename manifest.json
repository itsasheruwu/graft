{
  "manifest_version": 3,
  "name": "Graft",
  "description": "A focused kit for grafting small fixes onto the web.",
  "version": "1.0.0",
  "minimum_chrome_version": "111",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://youtube.com/*",
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://music.youtube.com/*",
    "https://*.youtube.com/*",
    "https://translate.googleapis.com/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background/service_worker.js"
  },
  "icons": {
    "16": "src/assets/icons/graft-16.png",
    "32": "src/assets/icons/graft-32.png",
    "48": "src/assets/icons/graft-48.png",
    "128": "src/assets/icons/graft-128.png"
  },
  "action": {
    "default_title": "Graft",
    "default_icon": {
      "16": "src/assets/icons/graft-16.png",
      "32": "src/assets/icons/graft-32.png",
      "48": "src/assets/icons/graft-48.png",
      "128": "src/assets/icons/graft-128.png"
    },
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": []
}
