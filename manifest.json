{
  "manifest_version": 3,
  "name": "Browser Tweaks",
  "description": "A collection of small Chrome browser tweaks.",
  "version": "1.0.0",
  "minimum_chrome_version": "111",
  "permissions": ["storage"],
  "background": {
    "service_worker": "src/background/service_worker.js"
  },
  "action": {
    "default_title": "Browser Tweaks",
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/tweaks/theme-syncer/page.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/tweaks/theme-syncer/bridge.js"
      ],
      "run_at": "document_start"
    }
  ]
}
